# =============================================================================
# NomNomzBot Environment Variables
# =============================================================================
# Run ./deploy.sh — it generates this automatically.
# Or: cp .env.example .env  then fill in the values manually.
# Never commit .env to source control.
# =============================================================================

# --- Security Keys -----------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=

# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Database ----------------------------------------------------------------
POSTGRES_USER=nomnomzbot
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=
POSTGRES_DB=nomnomzbot

# --- Redis -------------------------------------------------------------------
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=

# --- Twitch (REQUIRED) -------------------------------------------------------
# Get from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_USERNAME=NomNomzBot

# --- URLs --------------------------------------------------------------------
# Your public API domain. Twitch redirect URIs are computed from this automatically.
# Example: https://api.yourdomain.com
API_BASE_URL=http://localhost:5080

# Your public frontend domain.
# Example: https://yourdomain.com
FRONTEND_URL=http://localhost:8081

# --- Deployment --------------------------------------------------------------
DEPLOYMENT_MODE=self-hosted
ASPNETCORE_ENVIRONMENT=Production

# --- Cloudflare Tunnel -------------------------------------------------------
# Get token from: https://one.dash.cloudflare.com/ -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# --- Optional: Spotify -------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Optional: Discord -------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Optional: YouTube -------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Optional: TTS -----------------------------------------------------------
AZURE_TTS_API_KEY=
AZURE_TTS_REGION=westeurope
ELEVENLABS_API_KEY=

# --- Port overrides (optional) -----------------------------------------------
# API_HTTP_PORT=5080
# WEB_PORT=8081
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# ADMINER_PORT=8082
